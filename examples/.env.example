# Discord Token (từ User Settings > Token hoặc devtools)
# WARNING: Không share token này!
DISCORD_TOKEN=your_token_here

# Channel ID để test (tìm bằng Developer Mode)
DISCORD_CHANNEL_ID=your_channel_id_here

# Guild ID (optional)
DISCORD_GUILD_ID=your_guild_id_here

# User ID để test (optional)
DISCORD_USER_ID=your_user_id_here

# Proxy (optional)
# PROXY=http://127.0.0.1:8080

# Debug mode (optional)
# DEBUG=True
